---
import Screen from "../layouts/Screen.astro";
import TimerScreen from "../components/TimerScreen.tsx";
import SponsorCarousel from "../components/SponsorCarousel.astro";
import SponsorCard from "../components/SponsorCard.astro";
import { PATROCINADORES, REGLAS } from "../data/torneo";

// Cronómetro manual: por defecto reglas de clasificatorios (1° a 5 goles · 7 min).
const ronda = "Partido";
const minutos = REGLAS.clasificatorio.minutos;
const objetivo = REGLAS.clasificatorio.goles;

const oro = PATROCINADORES.filter((p) => p.tier === "oro");
const izq = oro.slice(0, Math.ceil(oro.length / 2));
const der = oro.slice(Math.ceil(oro.length / 2));
---

<Screen title="Cronómetro" active="cronometro">
  <div class="flex min-h-[calc(100vh-76px)] flex-col lg:h-[calc(100vh-76px)]">
    <section class="relative flex-1 overflow-hidden">
      {/* Fondo de estadio */}
      <div
        class="absolute inset-0 bg-cover bg-center"
        style="background-image:url(/brand/fondo_cronometro.png)"
      >
      </div>
      <div
        class="absolute inset-0"
        style="background: linear-gradient(90deg, rgba(3,6,4,.78), rgba(3,6,4,.12) 26%, rgba(3,6,4,.12) 74%, rgba(3,6,4,.78)), radial-gradient(75% 65% at 50% 44%, transparent, rgba(3,6,4,.6))"
      >
      </div>

      {/* Contenido: patrocinadores · cronómetro · patrocinadores */}
      <div class="relative grid h-full grid-cols-1 items-center gap-6 px-6 py-6 lg:grid-cols-[minmax(210px,1fr)_auto_minmax(210px,1fr)] lg:px-10">
        <aside class="order-2 hidden flex-col justify-center gap-3 lg:order-1 lg:flex">
          <h3 class="mb-1 text-[11px] font-black uppercase tracking-[.3em] text-mundo-orange">
            Patrocinadores Oro
          </h3>
          {izq.map((p, i) => <SponsorCard patro={p} delay={i * 70} />)}
        </aside>

        <div class="order-1 flex justify-center lg:order-2">
          <TimerScreen client:load initialMinutes={minutos} golesObjetivo={objetivo} ronda={ronda} />
        </div>

        <aside class="order-3 hidden flex-col justify-center gap-3 lg:flex">
          <h3 class="mb-1 text-right text-[11px] font-black uppercase tracking-[.3em] text-mundo-orange">
            Patrocinadores Oro
          </h3>
          {der.map((p, i) => <SponsorCard patro={p} delay={i * 70} />)}
        </aside>
      </div>
    </section>

    <SponsorCarousel tiers={["plata", "bronce"]} label="Patrocinadores Plata y Bronce" speedSeconds={32} />
  </div>
</Screen>
