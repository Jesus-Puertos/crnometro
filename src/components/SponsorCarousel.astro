---
import { PATROCINADORES, type Tier } from "../data/torneo";

interface Props {
  /** Filtra por categoría; por defecto muestra todos. */
  tiers?: Tier[];
  speedSeconds?: number;
  label?: string;
}

const { tiers, speedSeconds = 38, label = "Nuestros Patrocinadores" } = Astro.props;

const lista = tiers ? PATROCINADORES.filter((p) => tiers.includes(p.tier)) : PATROCINADORES;
// Duplicamos para un loop continuo sin costuras.
const track = [...lista, ...lista];

const tierRing: Record<Tier, string> = {
  oro: "#ffcb45",
  plata: "#cbd5e1",
  bronce: "#d08b54",
};
const tierLabel: Record<Tier, string> = { oro: "ORO", plata: "PLATA", bronce: "BRONCE" };
---

<section class="relative w-full overflow-hidden border-t border-white/10 bg-black/40 py-4 backdrop-blur-md">
  <div class="mb-2.5 flex items-center justify-center gap-3">
    <span class="h-px w-10 bg-gradient-to-r from-transparent to-mundo-orange/60"></span>
    <span class="text-[11px] font-black uppercase tracking-[.3em] text-mundo-orange">{label}</span>
    <span class="h-px w-10 bg-gradient-to-l from-transparent to-mundo-orange/60"></span>
  </div>

  <!-- Degradados laterales para desvanecer la cinta -->
  <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-black/80 to-transparent"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-black/80 to-transparent"></div>

  <div class="flex w-max animate-marquee items-center gap-4" style={`animation-duration:${speedSeconds}s`}>
    {
      track.map((p) => (
        <div class="flex shrink-0 items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.05] py-2.5 pl-2.5 pr-5 shadow-lg">
          {p.logo ? (
            <span class="flex h-14 min-w-14 shrink-0 items-center justify-center overflow-hidden rounded-xl bg-white/95 px-2">
              <img src={p.logo} alt={p.nombre} class="h-10 w-auto max-w-36 object-contain" />
            </span>
          ) : (
            <span
              class="grid h-14 w-14 place-items-center rounded-xl text-lg font-black text-white shadow-inner"
              style={`background:${p.color}`}
            >
              {p.iniciales}
            </span>
          )}
          <div class="flex flex-col leading-tight">
            <span class="text-[9px] font-black tracking-[.2em]" style={`color:${tierRing[p.tier]}`}>
              {tierLabel[p.tier]}
            </span>
            <span class="whitespace-nowrap text-sm font-extrabold text-white/90">{p.nombre}</span>
          </div>
        </div>
      ))
    }
  </div>
</section>
