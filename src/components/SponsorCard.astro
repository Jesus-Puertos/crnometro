---
import type { Patrocinador } from "../data/torneo";

interface Props {
  patro: Patrocinador;
  delay?: number;
}
const { patro, delay = 0 } = Astro.props;

const ring: Record<string, string> = { oro: "#ffcb45", plata: "#cbd5e1", bronce: "#d08b54" };
const label: Record<string, string> = { oro: "ORO", plata: "PLATA", bronce: "BRONCE" };
---

<div
  class="flex items-center gap-3 rounded-2xl border border-white/10 bg-black/45 py-2.5 pl-2.5 pr-4 backdrop-blur-md transition hover:border-white/20"
  style={`animation: rise .6s cubic-bezier(.16,1,.3,1) both; animation-delay:${delay}ms`}
>
  {
    patro.logo ? (
      <span class="flex h-14 min-w-14 shrink-0 items-center justify-center overflow-hidden rounded-xl bg-white/95 px-2">
        <img src={patro.logo} alt={patro.nombre} class="h-10 w-auto max-w-28 object-contain" />
      </span>
    ) : (
      <span
        class="grid h-14 w-14 shrink-0 place-items-center rounded-xl text-lg font-black text-white"
        style={`background:${patro.color}`}
      >
        {patro.iniciales}
      </span>
    )
  }
  <div class="min-w-0 leading-tight">
    <span class="text-[9px] font-black tracking-[.2em]" style={`color:${ring[patro.tier]}`}>
      {label[patro.tier]}
    </span>
    <span class="block truncate text-sm font-extrabold text-white/90">{patro.nombre}</span>
  </div>
</div>
